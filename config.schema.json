{
    "pluginAlias": "SomfyRtsPlatform",
    "pluginType": "platform",
    "singular": false,
    "strictValidation": true,
    "schema": {
        "type": "object",
        "properties": {
            "platform": {
                "title": "Platform",
                "type": "string",
                "const": "SomfyRtsPlatform"
            },
            "name": {
                "title": "Platform Name",
                "type": "string",
                "default": "Somfy RTS"
            },
            "devices": {
                "title": "Blinds",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "Device ID",
                            "description": "Stable unique ID (used for UUID generation).",
                            "type": "integer",
							"minimum": 0,
							"maximum": 16777216
                        },
                        "name": {
                            "title": "Name",
                            "type": "string"
                        },
                        "adminMode": {
                            "title": "Admin Mode",
                            "description": "Expose Up/Down/My/Prog buttons for initial programming.",
                            "type": "boolean",
                            "default": false
                        },
                        "invertToggle": {
                            "title": "Invert Direction",
                            "description": "Invert Up/Down for blinds that raise to close.",
                            "type": "boolean",
                            "default": false
                        },
                        "openToMyPosition": {
                            "title": "Open to My Position",
                            "description": "Use ‘MY’ for open instead of fully opening.",
                            "type": "boolean",
                            "default": false
                        },
                        "blindTimeToOpen": {
                            "title": "Time to Open (ms)",
                            "description": "Total travel time used to mock movement in HomeKit.",
                            "type": "integer",
							"minimum": 500,
							"maximum": 60000,
                            "default": 10000
                        },
						"repetitions": {
							"title": "Command Repetitions",
							"description": "Number of times to repeat each command. Sending multiple times may improve reception, however some blinds may detect it as a long button press, which only moves the blinds one step",
							"type": "integer",
							"minimum": 1,
							"maximum": 10,
							"default": 4
						}
                    },
                    "required": ["id", "name"]
                }
            }
        },
        "required": ["platform", "name", "devices"]
    }
}